    <DTS:Executable
      DTS:refId="Package\Load DimDate"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{358F285A-A9E5-4BDF-A4F0-B9DDE9678459}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Load DimDate"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{B8BDC302-5193-4D34-AFA2-5C51D2886B7B}"
          SQLTask:SqlStatementSource="DECLARE @start DATE = '2020-01-01'&#xA;DECLARE @end DATE = '2024-12-31'&#xA;DECLARE @d DATE = @start&#xA;&#xA;WHILE @d &lt;= @end&#xA;BEGIN&#xA;    INSERT INTO DimDate (date_sk, full_date, year, quarter, month, month_name, week, day_of_week, is_weekend)&#xA;    SELECT &#xA;        CAST(FORMAT(@d,'yyyyMMdd') AS INT),&#xA;        @d,&#xA;        YEAR(@d),&#xA;        DATEPART(QUARTER,@d),&#xA;        MONTH(@d),&#xA;        DATENAME(MONTH,@d),&#xA;        DATEPART(WEEK,@d),&#xA;        DATENAME(WEEKDAY,@d),&#xA;        CASE WHEN DATEPART(WEEKDAY,@d) IN (1,7) THEN 1 ELSE 0 END&#xA;    WHERE NOT EXISTS (&#xA;        SELECT 1 FROM DimDate WHERE date_sk = CAST(FORMAT(@d,'yyyyMMdd') AS INT)&#xA;    )&#xA;    SET @d = DATEADD(DAY,1,@d)&#xA;END" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
