              version="7">
              <properties>
                <property
                  dataType="System.Int32"
                  description="The number of seconds before a command times out.  A value of 0 indicates an infinite time-out."
                  name="CommandTimeout">0</property>
                <property
                  dataType="System.String"
                  description="Specifies the name of the database object used to open a rowset."
                  name="OpenRowset"></property>
                <property
                  dataType="System.String"
                  description="Specifies the variable that contains the name of the database object used to open a rowset."
                  name="OpenRowsetVariable"></property>
                <property
                  dataType="System.String"
                  description="The SQL command to be executed."
                  name="SqlCommand"
                  UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">SELECT
    TRY_CAST(DR_NO AS BIGINT) as dr_no,
    CAST(REPLACE(CONVERT(VARCHAR, TRY_CAST(DATE_OCC AS DATE), 112), '-', '') AS INT) as date_sk,
    TRY_CAST(AREA AS INT) as area_id,
    TRY_CAST(Crm_Cd AS INT) as crime_code,
    TRY_CAST(Vict_Age AS INT) as vict_age,
    LTRIM(RTRIM(Vict_Sex)) as vict_sex,
    LTRIM(RTRIM(Vict_Descent)) as vict_descent,
    TRY_CAST(Premis_Cd AS INT) as premise_code,
    TRY_CAST(TIME_OCC AS INT) as time_occurred,
    TRY_CAST(Weapon_Used_Cd AS INT) as weapon_code,
    LTRIM(RTRIM(Weapon_Desc)) as weapon_description,
    LTRIM(RTRIM(Status)) as status_code,
    LTRIM(RTRIM(Status_Desc)) as status_description,
    TRY_CAST(LAT AS FLOAT) as latitude,
    TRY_CAST(LON AS FLOAT) as longitude,
    GETDATE() as accm_txn_create_time
FROM LAPD_Staging
WHERE DR_NO IS NOT NULL</property>
                <property
