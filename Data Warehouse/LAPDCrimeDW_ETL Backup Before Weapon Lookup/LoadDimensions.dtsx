                <property
                  dataType="System.String"
                  description="The SQL command to be executed."
                  name="SqlCommand"
                  UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">SELECT DISTINCT
    TRY_CAST(AREA AS INT) as area_id,
    LTRIM(RTRIM(AREA_NAME)) as area_name,
    LTRIM(RTRIM(AREA_NAME)) as division,
    CAST('2020-01-01' AS DATE) as valid_from,
    CAST('9999-12-31' AS DATE) as valid_to,
    CAST(1 AS BIT) as is_current
FROM LAPD_Staging
WHERE AREA IS NOT NULL
AND ISNUMERIC(AREA) = 1</property>
