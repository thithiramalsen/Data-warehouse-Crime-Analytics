      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{96992F07-75CD-47F9-9508-1A47D0829D03}"
          SQLTask:SqlStatementSource="UPDATE f&#xA;SET &#xA;    f.accm_txn_complete_time = a.accm_txn_complete_time,&#xA;    f.txn_process_time_hours = DATEDIFF(HOUR, f.accm_txn_create_time, a.accm_txn_complete_time)&#xA;FROM FactCrimeIncident f&#xA;INNER JOIN AccumulatingUpdates a ON f.dr_no = a.dr_no&#xA;WHERE a.accm_txn_complete_time IS NOT NULL;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
